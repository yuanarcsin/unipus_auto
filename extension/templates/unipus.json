{
  "siteId": "unipus",
  "siteName": "Unipus (U校园)",
  "urlPatterns": [
    "*://ucontent.unipus.cn/*",
    "*://ucloud.unipus.cn/*"
  ],
  "urlRegex": "^https?://(?:ucontent|ucloud)\\.unipus\\.cn/",
  "version": "1.1.0",
  "createdAt": "2026-05-16",
  "lastUpdated": "2026-05-20",
  "description": "Unipus 外语教学平台练习题型（兼容新旧页面）",
  "selectors": {
    "questionContainer": "[class*='question-common-abs-choice'], [class*='question-common-abs-question-container'], [class*='question-abs-material']",
    "questionTypes": {
      "banked_cloze": {
        "detect": ".question-abs-material-banked-cloze",
        "container": "[class*='banked-cloze']",
        "title": "[class*='question-basic'], [class*='material'] p, [class*='title']",
        "wordOptions": ".option",
        "blanks": "[class*='banked-cloze-scoop'] input[type='text']",
        "wordBank": ".question-material-banked-cloze-reply",
        "clickTarget": "click_option_then_blank"
      },
      "single_choice": {
        "detect": ".question-abs-material-single-choice",
        "container": "[class*='single-choice']",
        "title": "[class*='question-basic'], [class*='stem'], [class*='title']",
        "optionsContainer": "[class*='question-items'], [class*='options'], [class*='choice']",
        "optionInput": "input[type='radio']",
        "optionLabel": "label",
        "clickTarget": "input[type='radio']"
      },
      "fill_blank": {
        "detect": ".question-abs-material-blank-filling",
        "container": "[class*='blank-filling']",
        "title": "[class*='question-basic'], [class*='material'] p",
        "inputs": "input[type='text'], textarea"
      },
      "translation": {
        "detect": ".question-abs-material-translation",
        "container": "[class*='translation']",
        "title": "[class*='question-basic'], [class*='material'] p",
        "inputs": "textarea, input[type='text']"
      },
      "rewrite_sentence": {
        "detect": ".question-abs-material-rewrite",
        "container": "[class*='rewrite']",
        "title": "[class*='question-basic'], [class*='material'] p",
        "inputs": "input[type='text'], textarea"
      },
      "grammar_fill": {
        "detect": ".question-abs-material-grammar",
        "container": "[class*='grammar']",
        "title": "[class*='question-basic'], [class*='material'] p",
        "inputs": "input[type='text']"
      },
      "choice": {
        "container": "[class*='question-common-abs-choice']",
        "title": ".ques-title, [class*='question-basic']",
        "optionItem": ".option-wrap",
        "optionInput": ".option",
        "optionLabel": ".option",
        "clickTarget": ".option"
      },
      "blank": {
        "container": "[class*='question-common-abs-reply']:not([class*='choice'])",
        "title": ".ques-title, [class*='question-basic']",
        "inputs": "input[type='text'], textarea"
      }
    }
  },
  "features": {
    "hasQuestionIndex": false,
    "hasTypeAttribute": false,
    "inputsHidden": false,
    "needClickWrapper": true,
    "autoScrollSupport": true,
    "isSPA": true
  },
  "notes": "U校园 SPA。兼容旧版 question-abs-material 和新版 question-common-abs-question-container。新版选择题使用 div.option 而非 input[type='radio']。"
}
