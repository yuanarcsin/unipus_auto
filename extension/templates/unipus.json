{
  "siteId": "unipus",
  "siteName": "Unipus (U校园)",
  "urlPatterns": [
    "*://ucontent.unipus.cn/*",
    "*://ucloud.unipus.cn/*"
  ],
  "urlRegex": "^https?://(?:ucontent|ucloud)\\.unipus\\.cn/",
  "version": "1.0.0",
  "createdAt": "2026-05-16",
  "lastUpdated": "2026-05-16",
  "description": "Unipus 外语教学平台练习题型",
  "selectors": {
    "questionContainer": "[class*='question-abs-material']",
    "questionTypes": {
      "detectByClass": true,
      "banked_cloze": {
        "detect": ".question-abs-material-banked-cloze",
        "container": "[class*='banked-cloze']",
        "title": "[class*='material'] p, [class*='title']",
        "wordOptions": ".option",
        "blanks": "[class*='banked-cloze-scoop'] input[type='text']",
        "wordBank": ".question-material-banked-cloze-reply",
        "clickTarget": "click_option_then_blank"
      },
      "single_choice": {
        "detect": ".question-abs-material-single-choice",
        "container": "[class*='single-choice']",
        "title": "[class*='stem'], [class*='title']",
        "optionsContainer": "[class*='question-items'], [class*='options']",
        "optionInput": "input[type='radio']",
        "optionLabel": "label",
        "clickTarget": "input[type='radio']"
      },
      "fill_blank": {
        "detect": ".question-abs-material-blank-filling",
        "container": "[class*='blank-filling']",
        "title": "[class*='material'] p",
        "inputs": "input[type='text'], textarea"
      },
      "translation": {
        "detect": ".question-abs-material-translation",
        "container": "[class*='translation']",
        "title": "[class*='material'] p",
        "inputs": "textarea, input[type='text']"
      },
      "rewrite_sentence": {
        "detect": ".question-abs-material-rewrite",
        "container": "[class*='rewrite']",
        "title": "[class*='material'] p",
        "inputs": "input[type='text'], textarea"
      },
      "grammar_fill": {
        "detect": ".question-abs-material-grammar",
        "container": "[class*='grammar']",
        "title": "[class*='material'] p",
        "inputs": "input[type='text']"
      }
    }
  },
  "features": {
    "hasQuestionIndex": false,
    "hasTypeAttribute": false,
    "inputsHidden": false,
    "needClickWrapper": true,
    "autoScrollSupport": true,
    "isSPA": true
  },
  "notes": "U校园 SPA 应用。选词填空题需特殊处理：点击 .option 选词 → 点击空位填入。翻译/改写题为 textarea。"
}
